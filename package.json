{
  "name": "@rheopyrin/db-access-mcp",
  "version": "0.1.1",
  "description": "MCP stdio server that gives AI agents access to Postgres, MySQL, Redshift and SQL Server — with SSH/AWS SSM tunnels and pluggable secret providers (env, Vault, AWS Secrets Manager, RDS IAM).",
  "license": "MIT",
  "author": "Rheopyrin",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rheopyrin/db-access-mcp.git"
  },
  "homepage": "https://github.com/Rheopyrin/db-access-mcp#readme",
  "bugs": {
    "url": "https://github.com/Rheopyrin/db-access-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "db-access-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "ai-agents",
    "database",
    "postgres",
    "mysql",
    "redshift",
    "sql-server",
    "mssql",
    "ssh-tunnel",
    "aws-ssm",
    "hashicorp-vault",
    "aws-secrets-manager",
    "rds-iam",
    "typescript",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "npm run build && vitest run test/e2e",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-redshift": "^3.1085.0",
    "@aws-sdk/client-secrets-manager": "^3.1085.0",
    "@aws-sdk/credential-providers": "^3.1085.0",
    "@aws-sdk/rds-signer": "^3.1085.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "inversify": "^8.1.3",
    "mssql": "^12.7.0",
    "mysql2": "^3.22.6",
    "node-vault": "^0.12.0",
    "pg": "^8.22.0",
    "pg-connection-string": "^2.14.0",
    "pg-cursor": "^2.21.0",
    "ssh2": "^1.17.0",
    "tslib": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "@types/ssh2": "^1.15.5",
    "eslint": "^10.7.0",
    "testcontainers": "^12.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
